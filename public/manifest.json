{
  "manifest_version": 3,
  "name": "Highlightr",
  "version": "1.0.0",
  "description": "Save highlights from any webpage",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icons/icon48.png" }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  }
}
